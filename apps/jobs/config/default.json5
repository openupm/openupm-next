{
  // Debug flag.
  debug: true,

  // Data directory.
  dataDir: '/data/openupm-data',

  // Redis.
  redis: {
    host: '127.0.0.1',
    port: 6379,
    db: 0,
  },

  // GitHub.
  github: {
    // Round-robin tokens for GitHub API calls.
    tokens: [],
  },

  // S3.
  s3: {
    config: {
      endpoint: '',
      accessKeyId: '',
      secretAccessKey: '',
      s3ForcePathStyle: true,
    },
    mediaBucket: 'openupm',
  },

  // How many ads to show for each package detail page.
  packageDetailAdsCount: 2,

  // Ad keyword maximum limit.
  adKeywordMaxLimit: 5,

  // Ad keyword maximum keyphrases token limit.
  // For example, "unity package manager" has 3 tokens.
  adKeywordMaxKeyphrasesTokenLimit: 2,

  // The content per page for the asset store search API.
  adSearchAssetStorePageSize: 20,

  // The limited size of ad-assetstore list for each package.
  packageToAdAssetStoreIdListSize: 10,

  // The limited size of ad-assetstore list for each topic.
  topicToAdAssetStoreIdListSize: 100,

  // The rate limit for the asset store search API.
  searchAssetStoreRateLimit: {
    interval: 4000, // ms
    rate: 1,
  },

  // The rate limit for the asset store linkmaker embed API.
  fetchLinkerMakerEmbedRateLimit: {
    interval: 2000, // ms
    rate: 1,
  },

  // PackageExtra
  packageExtra: {
    // 1 day
    image: { width: 600, height: 300, duration: 86400000 },
    avatar: {
      small: { size: 48, duration: 86400000 },
      normal: { size: 128, duration: 86400000 },
    },
  },

  // Cron job switches. Keep defaults enabled for production; override in
  // migration/local config when a job has side effects that are not safe yet.
  jobs: {
    fetchPackageToAdAssetStoreIdsJob: {
      enabled: true,
    },
    fetchTopicToAdAssetStoreIdsJob: {
      enabled: true,
    },
    aggregatePackageExtraJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
    updateFeedsJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
    fetchSiteInfoJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
    fetchPackageExtraJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
    fetchBackerDataJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
    updateRecentPackagesJob: {
      enabled: true,
      healthcheckPingUrl: '',
    },
  },
}
