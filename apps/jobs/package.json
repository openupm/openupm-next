{
  "private": true,
  "name": "@openupm/jobs",
  "version": "0.0.0",
  "type": "module",
  "author": "Favo Yang <favoyang@users.noreply.github.com>",
  "license": "BSD-3-Clause",
  "main": "build/index.js",
  "scripts": {
    "start": "node build/index.js",
    "start:dev": "nodemon --watch config --watch build --watch ../../packages build/index.js",
    "clean": "rimraf coverage build tmp",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "tsc -p tsconfig.json --sourceMap false --removeComments",
    "demo:markdown": "npm --prefix ../.. run build -- --filter=@openupm/common --filter=@openupm/local-data --filter=@openupm/server-common --filter=@openupm/ads --filter=@openupm/jobs && node scripts/render-readme-markdown-comparison.mjs",
    "lint": "eslint . --ext .ts --ext .mts",
    "test": "cross-env NODE_ENV=test vitest run --config vitest.config.js",
    "prettier": "prettier --config .prettierrc --write .",
    "test:watch": "cross-env NODE_ENV=test vitest --config vitest.config.js",
    "docker:build": "sudo docker buildx build -t favoyang/openupm-jobs ../.. -f Dockerfile",
    "docker:run": "sudo docker run -it --rm --network=host favoyang/openupm-jobs",
    "docker:push": "docker push favoyang/openupm-jobs:latest"
  },
  "dependencies": {
    "@openupm/ads": "*",
    "@openupm/server-common": "*",
    "config": "^4.4.1",
    "cron": "^3.1.6",
    "dotenv-flow": "^4.0.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.3",
    "node-emoji": "^2.2.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tslib": "~2.6",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "url-join": "^5.0.0"
  }
}
