{
  // Data directory.
  dataDir: '/data/openupm-data',

  // Redis.
  redis: {
    host: '127.0.0.1',
    port: 6379,
    db: 0,
  },

  // Queue.
  queueSettings: {
    pkg: {
      concurrency: 5,
      defaultJobOptions: {
        removeOnComplete: true,
        removeOnFail: false,
        attempts: 3,
        timeout: 60000,
        backoff: {
          type: 'exponential',
          delay: 30000,
        },
      },
    },
    rel: {
      concurrency: 5,
      defaultJobOptions: {
        removeOnComplete: true,
        removeOnFail: false,
        attempts: 3,
        timeout: 60000,
        backoff: {
          type: 'exponential',
          delay: 30000,
        },
      },
    },
  },

  jobs: {
    buildPackage: {
      queue: 'pkg',
      name: 'build-pkg',
      timeout: 300000,
    },
    buildRelease: {
      queue: 'rel',
      name: 'build-rel',
      timeout: 1800000,
      interval: 30000,
    },
  },

  // GitHub.
  github: {
    // Round-robin tokens for GitHub access.
    tokens: [],
  },

  // Azure devops.
  azureDevops: {
    endpoint: 'https://dev.azure.com/openupm',
    token: '',
    project: 'openupm',
    definitionId: 1,
    check: {
      // The estimated wait time for azure to process a build.
      duration: 45000,
      // Repeat check count.
      retries: 5,
      // Repeat interval step - [interval, interval * 2, ..., interval * retries].
      retryIntervalStep: 10000,
    },
    buildUrlBase: 'https://dev.azure.com/openupm/43915a16-5763-427d-8190-b9eccec12894/',
  },
}
