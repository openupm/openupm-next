{
  "private": true,
  "name": "@openupm/ads",
  "version": "0.0.0",
  "type": "module",
  "author": "Favo Yang <favoyang@users.noreply.github.com>",
  "license": "BSD-3-Clause",
  "main": "build/index.js",
  "devDependencies": {
    "nock": "^13.5.1"
  },
  "scripts": {
    "start": "node build/main.js",
    "clean": "rimraf coverage build tmp",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "tsc -p tsconfig.json --sourceMap false --removeComments",
    "postbuild": "chmod +x build/jobs/adAssetStoreCLI.js",
    "lint": "eslint . --ext .ts --ext .mts",
    "test": "cross-env NODE_ENV=test vitest run --config vitest.config.js",
    "prettier": "prettier --config .prettierrc --write .",
    "test:watch": "cross-env NODE_ENV=test vitest --config vitest.config.js"
  },
  "bin": {
    "adAssetStore": "build/jobs/adAssetStoreCLI.js"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^11.1.0",
    "@openupm/local-data": "*",
    "@openupm/server-common": "*",
    "@openupm/types": "*",
    "commander": "^11.1.0",
    "config": "^3.3.10",
    "dotenv-flow": "^4.0.1",
    "nlcst-to-string": "^4.0.0",
    "node-fetch": "^3.3.2",
    "p-ratelimit": "^1.0.1",
    "retext": "^9.0.0",
    "retext-keywords": "^8.0.1",
    "retext-pos": "^5.0.0",
    "ts-log": "^2.2.5",
    "tslib": "~2.6"
  },
  "volta": {
    "node": "18.18.2"
  }
}
