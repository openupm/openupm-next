{
  "private": true,
  "name": "vuepress-plugin-openupm",
  "version": "0.0.0",
  "type": "module",
  "author": "Favo Yang <favoyang@users.noreply.github.com>",
  "license": "BSD-3-Clause",
  "main": "build/index.js",
  "devDependencies": {
    "dotenv-flow": "^4.0.1"
  },
  "scripts": {
    "clean": "rimraf coverage build tmp",
    "prebuild": "npm run lint",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "tsc -p tsconfig.json --sourceMap false --removeComments",
    "lint": "eslint . --ext .ts --ext .mts",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest -i --coverage",
    "prettier": "prettier --config .prettierrc --write .",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "vue": "^3.4.19",
    "@vuepress/core": "2.0.0-rc.7",
    "@vuepress/utils": "2.0.0-rc.7",
    "lodash-es": "~4.17",
    "spdx-license-list": "~6.8",
    "tslib": "~2.6",
    "@openupm/types": "*",
    "@openupm/local-data": "*"
  },
  "peerDependencies": {
    "vuepress": "2.0.0-rc.7"
  },
  "volta": {
    "node": "18.18.2"
  }
}
